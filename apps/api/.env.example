# mokaid API — environment variables (dev)
# Production values come from AWS Secrets Manager / SSM via ECS task definitions.

DATABASE_URL=ecto://mokaid:mokaid_dev_password@localhost/mokaid_dev
SECRET_KEY_BASE=change_me_generate_with_mix_phx_gen_secret
PHX_HOST=localhost
PORT=4000

# S3 / MinIO
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY_ID=mokaid
S3_SECRET_ACCESS_KEY=mokaid_dev_password
S3_BUCKET_UPLOADS=mokaid-user-uploads-dev
S3_BUCKET_PRIVATE=mokaid-private-files-dev
S3_BUCKET_OUTPUTS=mokaid-generated-outputs-dev
S3_BUCKET_EXPORTS=mokaid-exports-dev

# AI worker
AI_WORKER_URL=http://localhost:8100
AI_WORKER_TOKEN=dev-worker-token

# Cognito (production only)
COGNITO_REGION=
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=

# CORS
CORS_ORIGINS=http://localhost:5173

# Figma OAuth (MCP Hub) — real values live in AWS Secrets Manager
# (mokaid-dev/figma_client_id, mokaid-dev/figma_client_secret)
FIGMA_CLIENT_ID=
FIGMA_CLIENT_SECRET=
FIGMA_REDIRECT_URI=http://localhost:5173/oauth/figma/callback

# Credentials-at-rest encryption (optional; derives from SECRET_KEY_BASE if unset)
# 32 bytes base64: openssl rand -base64 32
ENCRYPTION_KEY=
